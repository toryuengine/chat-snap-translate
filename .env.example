# ============================================================
# ゲームチャット翻訳ツール — API 設定
# このファイルを .env にコピーして値を入力してください
# ============================================================

# 使用するプロバイダー: openai または anthropic
API_PROVIDER=openai

# ---- OpenAI (ChatGPT) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
